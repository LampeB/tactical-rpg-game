# Godot 4+ specific ignores
.godot/
*.translation

# Debug logs (generated at runtime)
debug_log.txt
battle_log.txt
tools/*_log.txt

# Generated tool caches
tools/wall_grid.bin

# Local test scenes (often bloated by Generate All; never commit)
scenes/maps/*_test.tscn
scenes/maps/*_ortho_test.tscn

# OS generated files
.DS_Store
Thumbs.db

# Vendor asset packs (large third-party downloads)
temp_sprites/
assets/3D/
assets/import/

# MCP config (contains API keys)
.mcp.json

# Build output
build/
builds/

# Old root-level directories (not used)
/src/
/sprites/
