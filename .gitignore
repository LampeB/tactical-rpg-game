# Godot 4+ specific ignores
.godot/
*.translation

# Debug log (generated at runtime)
debug_log.txt

# OS generated files
.DS_Store
Thumbs.db

# Vendor asset packs (large third-party downloads)
temp_sprites/
assets/3D/

# MCP config (contains API keys)
.mcp.json

# Build output
build/
builds/

# Old root-level directories (not used)
/src/
/sprites/
